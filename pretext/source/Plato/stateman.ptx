        <p xml:id="plato-stateman-colophon-p-2">Translated by Benjamin Jowett</p>
        <p xml:id="plato-stateman-colophon-p-3">Written: 360 BCE</p>
      </colophon>
    </backmatter>
  </book>
</pretext>